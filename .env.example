# Telegram credentials — get from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=         # your phone number with country code, e.g. +14165287743

# MetaTrader 5 account credentials
# MT5_SERVER is the broker server name shown on the MT5 login screen (e.g. ICMarkets-Demo)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Order execution safety switch
# Keep true during testing — set to false only when ready to place real orders
DRY_RUN=true

# Future use — LLM fallback parser (not yet implemented)
# ANTHROPIC_API_KEY=
